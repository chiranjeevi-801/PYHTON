   "source": [
    "## 4. Polymorphism\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "47540f29",
   "metadata": {},
   "source": [
    "\n",
    "\n",
    "Polymorphism means one method can have different implementations in different classes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2be8de4a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Bark\n",
      "Meow\n"
     ]
    }
   ],
   "source": [
    "class Dog:\n",
    "    def sound(self):\n",
    "        print(\"Bark\")\n",
    "\n",
    "class Cat:\n",
    "    def sound(self):\n",
    "        print(\"Meow\")\n",
    "\n",
    "d = Dog()\n",
    "c = Cat()\n",
    "\n",
    "d.sound()\n",
    "c.sound()"
   ]
  },
